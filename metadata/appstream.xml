<?xml version="1.0" encoding="UTF-8"?>
<components version="1.0" origin="somaos">
  <component type="desktop-application">
    <id>org.somaos.UnrealEngineManager</id>
    <pkgname>soma-unreal-manager</pkgname>
    <name>Unreal Engine Manager</name>
    <summary>Install Epic's native Linux Unreal Engine builds</summary>
    <metadata_license>MIT</metadata_license>
    <project_license>MIT</project_license>
    <developer id="org.somaos">
      <name>Soma OS</name>
    </developer>
    <description>
      <p>
        Installs and launches native Linux Unreal Engine builds downloaded
        directly by the user from Epic Games.
      </p>
      <p>
        Keep multiple engine versions side-by-side and launch them through
        Soma's GPU-P Vulkan compatibility layer. Epic authentication and
        license acceptance take place on Epic's website.
      </p>
      <p>
        Fab is included in current Unreal Engine releases. Quixel Bridge is a
        legacy workflow and is not installed separately.
      </p>
    </description>
    <launchable type="desktop-id">org.somaos.UnrealEngineManager.desktop</launchable>
    <icon type="stock">org.somaos.UnrealEngineManager</icon>
    <provides>
      <binary>soma-unreal-manager</binary>
      <binary>soma-unreal-launch</binary>
    </provides>
    <categories>
      <category>Development</category>
      <category>IDE</category>
      <category>Graphics</category>
    </categories>
    <keywords>
      <keyword>Unreal Engine</keyword>
      <keyword>Epic Games</keyword>
      <keyword>Fab</keyword>
      <keyword>game development</keyword>
    </keywords>
    <url type="homepage">https://github.com/frossdelaqrois/SomaOS-Packages</url>
    <url type="help">https://dev.epicgames.com/documentation/unreal-engine/linux-development-quickstart-for-unreal-engine</url>
    <content_rating type="oars-1.1"/>
    <releases>
      <release version="0.1.0" date="2026-07-23">
        <description>
          <p>Initial Discover catalog integration and multi-version Linux engine manager.</p>
        </description>
      </release>
    </releases>
  </component>
</components>
